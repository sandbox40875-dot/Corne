#include <behaviors.dtsi>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/rgb.h>

/ {

    keymap {
        compatible = "zmk,keymap";

        /* =========================
         * BASE LAYER
         * ========================= */
        base {
            bindings = <
&kp ESC     &kp Q    &kp W    &kp E    &kp R    &kp T       &kp Y    &kp U    &kp I    &kp O    &kp P    &kp BSPC
&kp LSHFT   &kp A    &kp S    &kp D    &kp F    &kp G       &kp H    &kp J    &kp K    &kp L    &kp SQT  &kp RSHFT
&kp LCTRL   &kp LALT &kp Z    &kp X    &kp C    &kp V       &kp B    &kp N    &kp M    &kp COMMA &kp DOT  &kp DEL
                          &kp LGUI    &lt 1 TAB  &kp SPACE   &kp ENTER &lt 2 ESC  &kp PERIOD
            >;
        };

        /* =========================
         * FN / RGB CONTROL LAYER
         * ========================= */
        fn {
            bindings = <

/* Row 1 */
&kp F1  &kp F2  &kp F3  &kp F4  &kp F5  &kp F6    &kp F7  &kp F8   &kp F9   &kp F10  &kp F11  &kp F12

/* Row 2 — RGB core controls */
&bt BT_CLR
&bt BT_CLR_ALL
&rgb_ug_toggle          /* ON / OFF */
&rgb_ug_mode            /* change effect */
&rgb_ug_brt_up          /* brightness up */
&rgb_ug_brt_down        /* brightness down */
&rgb_ug_speed_up        /* animation speed up */
&rgb_ug_speed_down      /* animation speed down */
&rgb_ug_hue_up          /* color change */
&rgb_ug_hue_down
&rgb_ug_sat_up
&rgb_ug_sat_down

/* Row 3 — Bluetooth + media */
&trans
&bt BT_SEL 0
&bt BT_SEL 1
&bt BT_SEL 2
&bt BT_SEL 3
&bt BT_SEL 4
&kp C_VOL_DN
&kp C_VOL_UP
&kp MUTE
&trans
&trans
&trans

/* Thumb row */
                &trans   &trans   &kp SPACE   &kp ENTER   &trans   &trans
            >;
        };

        /* =========================
         * SYS LAYER
         * ========================= */
        sys {
            bindings = <
&kp GRAVE &kp N1 &kp N2 &kp N3 &kp N4 &kp N5   &kp N6 &kp N7 &kp N8 &kp N9 &kp N0 &trans
&trans    &trans &trans &trans &trans &trans   &trans &trans &trans &trans &trans &trans
&trans    &trans &trans &trans &trans &trans   &trans &trans &trans &trans &trans &trans
                     &trans &trans &trans &trans &trans &trans
            >;
        };

    };
};